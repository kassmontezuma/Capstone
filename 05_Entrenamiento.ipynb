        "    factor=0.5,\n",
        "    patience=3\n",
        ")\n",
        "\n",
        "EARLY_STOPPING = 7\n",
        "\n",
        "print(\"Configuración\")\n",
        "\n",
        "print(\"Learning Rate:\",LEARNING_RATE)\n",
        "print(\"Epochs:\",NUM_EPOCHS)\n",
        "print(\"Batch Size:\",BATCH_SIZE)"
      ],
